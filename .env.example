# ═══════════════════════════════════════════════════
# The Endless Dreams — Environment Configuration
# ═══════════════════════════════════════════════════
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# All API keys are OPTIONAL — the app uses mock/fallback
# data when keys are missing, so it works out of the box.
# ═══════════════════════════════════════════════════

# ── Django ──
DJANGO_SETTINGS_MODULE=config.settings.development
SECRET_KEY=your-secret-key-here
DEBUG=True

# ── Database (optional — falls back to SQLite) ──
DB_NAME=endless_dreams
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432

# ── Redis (optional — falls back to in-memory) ──
REDIS_URL=redis://localhost:6379/0

# ═══════════════════════════════════════════════════
# EXTERNAL API KEYS
# ═══════════════════════════════════════════════════
# Where to put them:
#   1. Copy this file → .env in the project root
#   2. Fill in the keys below
#   3. The Django backend reads them automatically via
#      os.environ in backend/config/settings/base.py
#
# For the frontend (Mapbox), prefix with NEXT_PUBLIC_.
# ═══════════════════════════════════════════════════

# OpenWeather — weather data for trip monitoring
# Get key: https://openweathermap.org/api  (free tier available)
OPENWEATHER_API_KEY=


# Mapbox — interactive maps in the frontend
# Get token: https://account.mapbox.com/access-tokens/  (free tier available)
MAPBOX_ACCESS_TOKEN=
NEXT_PUBLIC_MAPBOX_TOKEN=
# OpenAI — AI-powered itinerary generation
# Get key: https://platform.openai.com/api-keys  (pay-as-you-go)
OPENAI_API_KEY=

# Google Places — place details, photos, ratings
# Get key: https://console.cloud.google.com/apis/credentials  (free tier available)
GOOGLE_PLACES_API_KEY=

# Amadeus — flight search and booking data
# Get key: https://developers.amadeus.com/register  (free test tier)
AMADEUS_API_KEY=

# Exchange Rate API — real-time currency conversion
# Get key: https://www.exchangerate-api.com/  (free tier: 1500 req/month)
EXCHANGE_RATE_API_KEY=

# ── Frontend ──
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws
